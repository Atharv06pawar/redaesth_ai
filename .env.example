# Optional external APIs used for synthetic generation and authenticated Hugging Face access
REDAESTH_OPENAI_API_KEY=
REDAESTH_ANTHROPIC_API_KEY=
REDAESTH_HF_TOKEN=
REDAESTH_HUGGINGFACE_HUB_TOKEN=

# Base model selection
# Leave as read_from_file to use research/model_comparison/selected_model.txt
REDAESTH_BASE_MODEL_ID=read_from_file
# Leave as read_from_file to use research/model_comparison/selected_embedding_model.txt
REDAESTH_EMBEDDING_MODEL_ID=read_from_file
REDAESTH_SELECTED_MODEL_FILE=research/model_comparison/selected_model.txt
REDAESTH_SELECTED_EMBEDDING_MODEL_FILE=research/model_comparison/selected_embedding_model.txt
REDAESTH_LOAD_IN_4BIT=true
REDAESTH_MAX_SEQ_LENGTH=2048

# LoRA hyperparameters
REDAESTH_LORA_R=16
REDAESTH_LORA_ALPHA=32
REDAESTH_LORA_DROPOUT=0.05

# Training defaults
REDAESTH_LEARNING_RATE=0.0002
REDAESTH_LR_SCHEDULER_TYPE=cosine
REDAESTH_WARMUP_RATIO=0.05
REDAESTH_NUM_TRAIN_EPOCHS=3
REDAESTH_PER_DEVICE_TRAIN_BATCH_SIZE=2
REDAESTH_GRADIENT_ACCUMULATION_STEPS=4
REDAESTH_SEED=42

# Repository and data paths
REDAESTH_PROJECT_ROOT=D:\data
REDAESTH_DATA_DIR=data
REDAESTH_RAW_DATA_DIR=data\raw
REDAESTH_RAW_DATA_MANIFEST_PATH=data\raw\raw_data_manifest.json
REDAESTH_CLEANED_DATA_DIR=data\cleaned
REDAESTH_SCORED_DATA_DIR=data\scored
REDAESTH_SYNTHETIC_DATA_DIR=data\synthetic
REDAESTH_FINAL_DATA_DIR=data\final
REDAESTH_RETRIEVAL_CORPUS_DIR=data\retrieval_corpus
REDAESTH_CHECKPOINT_DIR=training\checkpoints
REDAESTH_EVALUATION_OUTPUT_DIR=evaluation\reports
REDAESTH_APPROVED_DATASETS_REPORT=research\dataset_discovery\reports\approved_datasets.json

# Memory and retrieval
REDAESTH_MEMORY_DB_PATH=data\memory.db
# Backward-compatible alias still accepted by config: REDAESTH_DB_PATH
REDAESTH_MEMORY_TOKEN_BUDGET=800
REDAESTH_RETRIEVAL_TOKEN_BUDGET=600
REDAESTH_RETRIEVAL_TOP_K=3
REDAESTH_VECTOR_DB_PATH=data\vector_store
# Backward-compatible alias still accepted by config: REDAESTH_VECTOR_STORE_PATH

# Synthetic generation
REDAESTH_SYNTHETIC_TARGET_COUNT=8000
REDAESTH_SYNTHETIC_QUALITY_THRESHOLD=0.75
REDAESTH_GENERATION_BATCH_SIZE=20

# Logging
REDAESTH_LOG_LEVEL=INFO
